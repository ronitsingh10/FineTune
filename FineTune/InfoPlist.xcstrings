    "NSAudioCaptureUsageDescription": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune 需要访问权限，才能控制各个应用的音量。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج FineTune إلى الوصول للتحكم في مستويات الصوت للتطبيقات الفردية."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune-এর পৃথক অ্যাপ্লিকেশনের জন্য ভলিউম স্তর নিয়ন্ত্রণ করতে অ্যাক্সেস প্রয়োজন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune necessita accés per controlar els nivells de volum per a aplicacions individuals."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune 需要存取權限來控制各個應用程式的音量等級。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune treba pristup za kontrolu razina glasnoće za pojedinačne aplikacije."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune potřebuje přístup k ovládání úrovní hlasitosti pro jednotlivé aplikace."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune har brug for adgang til at kontrollere lydstyrkeniveauer for individuelle applikationer."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune heeft toegang nodig om de volumeniveaus voor individuele toepassingen te regelen."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune needs access to control volume levels for individual applications."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune needs access to control volume levels for individual applications."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune needs access to control volume levels for individual applications."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune needs access to control volume levels for individual applications."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune tarvitsee pääsyn yksittäisten sovellusten äänenvoimakkuuden hallintaan."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune a besoin d’accéder aux niveaux de volume de contrôle pour les applications individuelles."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune a besoin d’accéder aux niveaux de volume de contrôle pour les applications individuelles."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune benötigt Zugriff, um die Lautstärke einzelner Anwendungen zu steuern."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το FineTune χρειάζεται πρόσβαση σε επίπεδα ελέγχου έντασης για μεμονωμένες εφαρμογές."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune ને વ્યક્તિગત એપ્લિકેશનો માટે વોલ્યુમ સ્તરોને નિયંત્રિત કરવા માટે ઍક્સેસની જરૂર છે."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune זקוק לגישה לשליטה ברמות עוצמת הקול עבור יישומים בודדים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune को व्यक्तिगत अनुप्रयोगों के लिए वॉल्यूम स्तर को नियंत्रित करने के लिए पहुंच की आवश्यकता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A FineTune-nek hozzáférésre van szüksége az egyes alkalmazások hangerejének szabályozásához."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune memerlukan akses untuk mengontrol level volume untuk masing-masing aplikasi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune necessita dell'accesso per controllare i livelli del volume per le singole applicazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune は、個々のアプリケーションのボリューム レベルを制御するためのアクセスを必要とします。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ವೈಯಕ್ತಿಕ ಅಪ್ಲಿಕೇಶನ್‌ಗಳಿಗಾಗಿ ವಾಲ್ಯೂಮ್ ಮಟ್ಟವನ್ನು ನಿಯಂತ್ರಿಸಲು FineTune ಗೆ ಪ್ರವೇಶದ ಅಗತ್ಯವಿದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune은 개별 애플리케이션의 볼륨 레벨을 제어하려면 액세스 권한이 필요합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune memerlukan akses untuk mengawal tahap kelantangan untuk aplikasi individu."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "വ്യക്തിഗത ആപ്ലിക്കേഷനുകൾക്കായി വോളിയം ലെവലുകൾ നിയന്ത്രിക്കാൻ FineTune-ന് ആക്സസ് ആവശ്യമാണ്."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune ला वैयक्तिक अनुप्रयोगांसाठी आवाज पातळी नियंत्रित करण्यासाठी प्रवेश आवश्यक आहे."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune trenger tilgang til å kontrollere volumnivåer for individuelle applikasjoner."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ବ୍ୟକ୍ତିଗତ ପ୍ରୟୋଗଗୁଡ଼ିକ ପାଇଁ ଭଲ୍ୟୁମ୍ ସ୍ତରକୁ ନିୟନ୍ତ୍ରଣ କରିବାକୁ FineTune ପ୍ରବେଶ ଆବଶ୍ୟକ କରେ |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune potrzebuje dostępu do kontroli poziomów głośności dla poszczególnych aplikacji."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune precisa de acesso para controlar os níveis de volume para aplicações individuais."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune precisa de acesso para controlar os níveis de volume para aplicações individuais."
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune ਨੂੰ ਵਿਅਕਤੀਗਤ ਐਪਲੀਕੇਸ਼ਨਾਂ ਲਈ ਵਾਲੀਅਮ ਪੱਧਰਾਂ ਨੂੰ ਨਿਯੰਤਰਿਤ ਕਰਨ ਲਈ ਪਹੁੰਚ ਦੀ ਲੋੜ ਹੈ।"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune are nevoie de acces pentru a controla nivelurile de volum pentru aplicații individuale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune необходим доступ к управлению уровнями громкости для отдельных приложений."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune potrebuje prístup na ovládanie úrovní hlasitosti pre jednotlivé aplikácie."
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune potrebuje dostop za nadzor ravni glasnosti za posamezne aplikacije."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune necesita acceso para controlar los niveles de volumen para aplicaciones individuales."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune necesita acceso para controlar los niveles de volumen para aplicaciones individuales."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune behöver tillgång för att kontrollera volymnivåer för individuella applikationer."
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "தனிப்பட்ட பயன்பாடுகளுக்கான வால்யூம் அளவைக் கட்டுப்படுத்த FineTune க்கு அணுகல் தேவை."
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "వ్యక్తిగత అనువర్తనాల కోసం వాల్యూమ్ స్థాయిలను నియంత్రించడానికి FineTuneకి యాక్సెస్ అవసరం."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune ต้องการเข้าถึงเพื่อควบคุมระดับเสียงสำหรับแต่ละแอปพลิเคชัน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune'in bireysel uygulamalar için ses seviyelerini kontrol etmek için erişime ihtiyacı var."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune потрібен доступ до керування рівнями гучності для окремих програм."
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune کو انفرادی ایپلی کیشنز کے لیے حجم کی سطح کو کنٹرول کرنے تک رسائی کی ضرورت ہے۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune cần quyền truy cập để kiểm soát mức âm lượng cho từng ứng dụng."
          }
        }
      }
    },
    "NSBluetoothAlwaysUsageDescription": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune 使用蓝牙，以便从菜单栏连接已配对的音频设备。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم FineTune تقنية Bluetooth لتوصيل أجهزة الصوت المقترنة من شريط القائمة."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune মেনু বার থেকে জোড়া অডিও ডিভাইস সংযোগ করতে ব্লুটুথ ব্যবহার করে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune utilitza Bluetooth per connectar dispositius d'àudio emparellats des de la barra de menús."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune 使用藍牙從功能表列連接配對的音訊裝置。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune koristi Bluetooth za povezivanje uparenih audio uređaja s trake izbornika."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune používá Bluetooth k připojení spárovaných zvukových zařízení z panelu nabídek."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune bruger Bluetooth til at forbinde parrede lydenheder fra menulinjen."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune gebruikt Bluetooth om gekoppelde audioapparaten via de menubalk te verbinden."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune uses Bluetooth to connect paired audio devices from the menu bar."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune uses Bluetooth to connect paired audio devices from the menu bar."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune uses Bluetooth to connect paired audio devices from the menu bar."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune uses Bluetooth to connect paired audio devices from the menu bar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune yhdistää Bluetoothin avulla pariksi liitetyt äänilaitteet valikkoriviltä."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune utilise Bluetooth pour connecter des appareils audio couplés à partir de la barre de menus."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune utilise Bluetooth pour connecter des appareils audio couplés à partir de la barre de menus."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune nutzt Bluetooth, um gekoppelte Audiogeräte über die Menüleiste zu verbinden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
