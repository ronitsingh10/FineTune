    "Use F11/F12 (or volume keys) to control FineTune": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 F11/F12（或音量键）控制 FineTune"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم F11/F12 (أو مفاتيح مستوى الصوت) للتحكم في FineTune"
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "নিয়ন্ত্রণ করতে F11/F12 (বা ভলিউম কী) ব্যবহার করুন FineTune"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilitzeu F11/F12 (o tecles de volum) per controlar FineTune"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用F11/F12（或音量鍵）控制FineTune"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koristite F11/F12 (ili tipke za glasnoću) za kontrolu FineTune"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Použijte F11/F12 (nebo klávesy hlasitosti) k ovládání FineTune"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Brug F11/F12 (eller lydstyrketasterne) til at styre FineTune"
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik F11/F12 (of volumetoetsen) om FineTune te bedienen"
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Use F11/F12 (or volume keys) to control FineTune"
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Use F11/F12 (or volume keys) to control FineTune"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Use F11/F12 (or volume keys) to control FineTune"
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Use F11/F12 (or volume keys) to control FineTune"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käytä F11/F12 (tai äänenvoimakkuusnäppäimiä) ohjataksesi FineTune"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez F11/F12 (ou les touches de volume) pour contrôler FineTune"
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez F11/F12 (ou les touches de volume) pour contrôler FineTune"
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie F11/F12 (oder Lautstärketasten), um FineTune zu steuern."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιήστε τα πλήκτρα F11/F12 (ή έντασης ήχου) για να ελέγξετε το FineTune"
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "નિયંત્રિત કરવા માટે F11/F12 (અથવા વોલ્યુમ કી) નો ઉપયોગ કરો FineTune"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השתמש ב-F11/F12 (או במקשי עוצמת הקול) כדי לשלוט ב-FineTune"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune को नियंत्रित करने के लिए F11/F12 (या वॉल्यूम कुंजियाँ) का उपयोग करें"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A FineTune vezérléséhez használja az F11/F12 gombot (vagy a hangerőgombokat)"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan F11/F12 (atau tombol volume) untuk mengontrol FineTune"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa F11/F12 (o i tasti del volume) per controllare FineTune"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "F11/F12 (またはボリューム キー) を使用して FineTune を制御します"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune ಅನ್ನು ನಿಯಂತ್ರಿಸಲು F11/F12 (ಅಥವಾ ವಾಲ್ಯೂಮ್ ಕೀಗಳು) ಬಳಸಿ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "F11/F12(또는 볼륨 키)를 사용하여 FineTune을 제어하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan F11/F12 (atau kekunci kelantangan) untuk mengawal FineTune"
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune നിയന്ത്രിക്കാൻ F11/F12 (അല്ലെങ്കിൽ വോളിയം കീകൾ) ഉപയോഗിക്കുക"
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "नियंत्रित करण्यासाठी F11/F12 (किंवा व्हॉल्यूम की) वापरा FineTune"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruk F11/F12 (eller volumtastene) for å kontrollere FineTune"
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune ନିୟନ୍ତ୍ରଣ କରିବାକୁ F11 / F12 (କିମ୍ବା ଭଲ୍ୟୁମ୍ କି) ବ୍ୟବହାର କରନ୍ତୁ |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj F11/F12 (lub klawiszy głośności), aby sterować FineTune"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use F11/F12 (ou teclas de volume) para controlar FineTune"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Use F11/F12 (ou teclas de volume) para controlar FineTune"
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ਕੰਟਰੋਲ ਕਰਨ ਲਈ F11/F12 (ਜਾਂ ਵਾਲੀਅਮ ਕੁੰਜੀਆਂ) ਦੀ ਵਰਤੋਂ ਕਰੋ FineTune"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizați F11/F12 (sau tastele de volum) pentru a controla FineTune"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте F11/F12 (или клавиши громкости) для управления FineTune"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Použite F11/F12 (alebo klávesy hlasitosti) na ovládanie FineTune"
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "Uporabite F11/F12 (ali tipke za glasnost) za nadzor FineTune"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice F11/F12 (o teclas de volumen) para controlar FineTune"
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice F11/F12 (o teclas de volumen) para controlar FineTune"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd F11/F12 (eller volymknapparna) för att styra FineTune"
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune ஐக் கட்டுப்படுத்த F11/F12 (அல்லது தொகுதி விசைகள்) பயன்படுத்தவும்"
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTuneని నియంత్రించడానికి F11/F12 (లేదా వాల్యూమ్ కీలు) ఉపయోగించండి"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ F11/F12 (หรือปุ่มปรับระดับเสียง) เพื่อควบคุม FineTune"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune'yi kontrol etmek için F11/F12'yi (veya ses seviyesi tuşlarını) kullanın"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовуйте F11/F12 (або клавіші гучності) для керування FineTune"
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "FineTune کو کنٹرول کرنے کے لیے F11/F12 (یا والیوم کیز) کا استعمال کریں"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sử dụng F11/F12 (hoặc phím âm lượng) để điều khiển FineTune"
