        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸಾಧನಗಳು ಸಂಪರ್ಕಗೊಂಡಾಗ ಸ್ವಯಂ-ಸ್ವಿಚಿಂಗ್ ಅನ್ನು ತಡೆಯಿರಿ"
