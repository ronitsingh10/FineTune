    "How much each keypress changes the volume. Applies to media keys, configured hotkeys, and arrow-key nav in the popup.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每次按键改变音量的幅度。适用于媒体键、自定义快捷键以及弹窗中的方向键导航。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "مقدار تغيير مستوى الصوت مع كل ضغطة مفتاح. ينطبق على مفاتيح الوسائط ومفاتيح التشغيل السريع التي تم تكوينها وتنقل مفاتيح الأسهم في النافذة المنبثقة."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতিটি কীপ্রেস কতটা ভলিউম পরিবর্তন করে। পপআপে মিডিয়া কী, কনফিগার করা হটকি এবং তীর-কী নেভিতে প্রযোজ্য।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Quant canvia el volum cada tecla que prem. S'aplica a les tecles multimèdia, les tecles d'accés directe configurades i la navegació amb les fletxes a la finestra emergent."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每次按鍵都會改變音量的程度。適用於彈出視窗中的媒體鍵、配置的熱鍵和箭頭鍵導覽。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koliko svaki pritisak tipke mijenja glasnoću. Primjenjuje se na medijske tipke, konfigurirane prečace i navigaciju pomoću tipki sa strelicama u skočnom prozoru."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak moc každé stisknutí klávesy změní hlasitost. Platí pro mediální klávesy, nakonfigurované klávesové zkratky a navigaci pomocí šipek ve vyskakovacím okně."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvor meget hvert tastetryk ændrer lydstyrken. Gælder for medietaster, konfigurerede genvejstaster og piletastnavigation i pop op-vinduet."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoeveel elke toetsaanslag het volume verandert. Geldt voor mediatoetsen, geconfigureerde sneltoetsen en navigatie met pijltjestoetsen in de pop-up."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "How much each keypress changes the volume. Applies to media keys, configured hotkeys, and arrow-key nav in the popup."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "How much each keypress changes the volume. Applies to media keys, configured hotkeys, and arrow-key nav in the popup."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "How much each keypress changes the volume. Applies to media keys, configured hotkeys, and arrow-key nav in the popup."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "How much each keypress changes the volume. Applies to media keys, configured hotkeys, and arrow-key nav in the popup."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuinka paljon jokainen näppäinpainallus muuttaa äänenvoimakkuutta. Koskee medianäppäimiä, määritettyjä pikanäppäimiä ja nuolinäppäimiä ponnahdusikkunassa."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans quelle mesure chaque pression sur une touche modifie le volume. S'applique aux touches multimédias, aux raccourcis clavier configurés et à la navigation par touches fléchées dans la fenêtre contextuelle."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans quelle mesure chaque pression sur une touche modifie le volume. S'applique aux touches multimédias, aux raccourcis clavier configurés et à la navigation par touches fléchées dans la fenêtre contextuelle."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie stark jeder Tastendruck die Lautstärke ändert. Gilt für Medientasten, konfigurierte Hotkeys und die Pfeiltastennavigation im Popup."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πόσο αλλάζει η ένταση κάθε πάτημα πλήκτρων. Ισχύει για πλήκτρα πολυμέσων, διαμορφωμένα πλήκτρα πρόσβασης και πλοήγηση με βέλη στο αναδυόμενο παράθυρο."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "દરેક કી દબાવવાથી વોલ્યુમ કેટલું બદલાય છે. પૉપઅપમાં મીડિયા કી, રૂપરેખાંકિત હોટકી અને એરો-કી નેવી પર લાગુ થાય છે."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "עד כמה כל לחיצה על מקש משנה את עוצמת הקול. חל על מקשי מדיה, מקשי קיצור מוגדרים וניווט מקש חצים בחלון הקופץ."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रत्येक कीप्रेस का वॉल्यूम कितना बदलता है। पॉपअप में मीडिया कुंजियों, कॉन्फ़िगर की गई हॉटकी और एरो-कुंजी नेविगेशन पर लागू होता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Mennyire változtatja meg a hangerőt minden egyes gombnyomás. A médiabillentyűkre, a konfigurált gyorsbillentyűkre és a felugró ablakban lévő nyílbillentyűs navigációra vonatkozik."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Seberapa besar perubahan volume setiap penekanan tombol. Berlaku untuk tombol media, tombol pintas yang dikonfigurasi, dan navigasi tombol panah di munculan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Di quanto ogni pressione di un tasto modifica il volume. Si applica ai tasti multimediali, ai tasti di scelta rapida configurati e alla navigazione con tasti freccia nel popup."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーを押すたびに音量がどのくらい変化しますか。メディア キー、設定されたホットキー、ポップアップの矢印キー ナビゲーションに適用されます。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಪ್ರತಿ ಕೀ ಪ್ರೆಸ್ ವಾಲ್ಯೂಮ್ ಅನ್ನು ಎಷ್ಟು ಬದಲಾಯಿಸುತ್ತದೆ. ಪಾಪ್‌ಅಪ್‌ನಲ್ಲಿ ಮೀಡಿಯಾ ಕೀಗಳು, ಕಾನ್ಫಿಗರ್ ಮಾಡಲಾದ ಹಾಟ್‌ಕೀಗಳು ಮತ್ತು ಬಾಣ-ಕೀ ನ್ಯಾವ್‌ಗೆ ಅನ್ವಯಿಸುತ್ತದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키를 누를 때마다 볼륨이 변경되는 정도입니다. 팝업의 미디어 키, 구성된 단축키 및 화살표 키 탐색에 적용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Berapa banyak setiap tekan kekunci mengubah kelantangan. Digunakan pada kekunci media, kekunci panas yang dikonfigurasikan dan navigasi kekunci anak panah dalam pop timbul."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ഓരോ കീ പ്രസ്സും എത്രമാത്രം വോളിയം മാറ്റുന്നു. പോപ്പ്അപ്പിലെ മീഡിയ കീകൾ, കോൺഫിഗർ ചെയ്‌ത ഹോട്ട്‌കീകൾ, ആരോ-കീ nav എന്നിവയ്‌ക്ക് ബാധകമാണ്."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रत्येक की दाबल्याने आवाज किती बदलतो. पॉपअपमधील मीडिया की, कॉन्फिगर केलेल्या हॉटकी आणि बाण-की nav वर लागू होते."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvor mye hvert tastetrykk endrer volumet. Gjelder mediataster, konfigurerte hurtigtaster og piltastnavigering i popup-vinduet."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ପ୍ରତ୍ୟେକ କିପ୍ରେସ୍ ଭଲ୍ୟୁମ୍ କେତେ ପରିବର୍ତ୍ତନ କରେ | ମିଡିଆ ଚାବି, ବିନ୍ୟାସିତ ହଟ୍କି, ଏବଂ ପପ୍ଅପ୍ ରେ ତୀର-କି ନାଭ ପାଇଁ ପ୍ରଯୁଜ୍ୟ |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak każde naciśnięcie klawisza zmienia głośność. Dotyczy klawiszy multimedialnych, skonfigurowanych skrótów klawiszowych i nawigacji za pomocą klawiszy strzałek w wyskakującym okienku."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanto cada pressionamento de tecla altera o volume. Aplica-se a teclas de mídia, teclas de atalho configuradas e navegação com teclas de seta no pop-up."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanto cada pressionamento de tecla altera o volume. Aplica-se a teclas de mídia, teclas de atalho configuradas e navegação com teclas de seta no pop-up."
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ਹਰੇਕ ਕੀਪ੍ਰੈਸ ਵਾਲੀਅਮ ਨੂੰ ਕਿੰਨਾ ਬਦਲਦਾ ਹੈ। ਪੌਪਅੱਪ ਵਿੱਚ ਮੀਡੀਆ ਕੁੰਜੀਆਂ, ਕੌਂਫਿਗਰ ਕੀਤੀਆਂ ਹੌਟਕੀਜ਼, ਅਤੇ ਐਰੋ-ਕੁੰਜੀ nav 'ਤੇ ਲਾਗੂ ਹੁੰਦਾ ਹੈ।"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cât de mult modifică volumul la fiecare apăsare de tastă. Se aplică tastelor media, tastelor rapide configurate și navigării cu tastele săgeată din fereastra pop-up."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Насколько сильно изменяется громкость при каждом нажатии клавиши. Применяется к мультимедийным клавишам, настроенным горячим клавишам и навигации с помощью клавиш со стрелками во всплывающем окне."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "O koľko každé stlačenie klávesu zmení hlasitosť. Vzťahuje sa na mediálne klávesy, nakonfigurované klávesové skratky a navigáciu so šípkami v kontextovom okne."
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "Koliko vsak pritisk tipke spremeni glasnost. Velja za medijske tipke, konfigurirane bližnjične tipke in navigacijo s puščičnimi tipkami v pojavnem oknu."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánto cambia el volumen con cada pulsación de tecla. Se aplica a las teclas multimedia, las teclas de acceso rápido configuradas y la navegación con teclas de flecha en la ventana emergente."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánto cambia el volumen con cada pulsación de tecla. Se aplica a las teclas multimedia, las teclas de acceso rápido configuradas y la navegación con teclas de flecha en la ventana emergente."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hur mycket varje knapptryckning ändrar volymen. Gäller mediatangenter, konfigurerade snabbtangenter och pilknappsnavigering i popup-fönstret."
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ஒவ்வொரு விசை அழுத்தும் அளவை எவ்வளவு மாற்றுகிறது. மீடியா விசைகள், உள்ளமைக்கப்பட்ட ஹாட்ஸ்கிகள் மற்றும் பாப்அப்பில் உள்ள அம்பு-விசை nav ஆகியவற்றுக்குப் பொருந்தும்."
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ప్రతి కీ ప్రెస్ వాల్యూమ్‌ను ఎంత మారుస్తుంది. పాప్‌అప్‌లో మీడియా కీలు, కాన్ఫిగర్ చేయబడిన హాట్‌కీలు మరియు బాణం-కీ navకి వర్తిస్తుంది."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การกดแต่ละครั้งจะเปลี่ยนระดับเสียงมากแค่ไหน ใช้กับปุ่มมีเดีย ปุ่มลัดที่กำหนดค่า และการนำทางด้วยปุ่มลูกศรในป๊อปอัป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her tuşa basıldığında ses düzeyi ne kadar değişir. Açılan penceredeki medya tuşları, yapılandırılmış kısayol tuşları ve ok tuşu gezintisi için geçerlidir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "На скільки кожне натискання клавіші змінює гучність. Застосовується до мультимедійних клавіш, налаштованих гарячих клавіш і навігації за допомогою клавіш зі стрілками у спливаючому вікні."
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "ہر کی پریس والیوم کو کتنا بدلتا ہے۔ پاپ اپ میں میڈیا کیز، کنفیگر شدہ ہاٹکیز، اور ایرو کلید نیوی پر لاگو ہوتا ہے۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mỗi lần nhấn phím sẽ thay đổi âm lượng bao nhiêu. Áp dụng cho các phím phương tiện, phím nóng được định cấu hình và điều hướng bằng phím mũi tên trong cửa sổ bật lên."
          }
        }
      }
    },
