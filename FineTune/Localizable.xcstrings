          "stringUnit": {
            "state": "translated",
            "value": "મીડિયા કી ઑફલાઇન. ઇવેન્ટ ટૅપને ફરીથી ઇન્સ્ટોલ કરવાનો ફરી પ્રયાસ કરો."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מקשי מדיה במצב לא מקוון. נסה שוב להתקין מחדש את הארוע הקש."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मीडिया कुंजी ऑफ़लाइन। इवेंट टैप को पुनः स्थापित करने का पुनः प्रयास करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Médiabillentyűk offline módban. Próbálja újra telepíteni az eseményt érintse meg."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunci media offline. Coba lagi untuk menginstal ulang tap acara."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tasti multimediali offline. Riprova a reinstallare il tocco dell'evento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メディア キーがオフラインです。イベントタップを再インストールしてみてください。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಮಾಧ್ಯಮ ಕೀಗಳು ಆಫ್‌ಲೈನ್. ಈವೆಂಟ್ ಟ್ಯಾಪ್ ಅನ್ನು ಮರುಸ್ಥಾಪಿಸಲು ಮರುಪ್ರಯತ್ನಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미디어 키가 오프라인입니다. 이벤트 탭을 다시 설치해 보세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kekunci media di luar talian. Cuba semula untuk memasang semula ketik acara."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "മീഡിയ കീകൾ ഓഫ്‌ലൈനിൽ. ഇവൻ്റ് ടാപ്പ് വീണ്ടും ഇൻസ്റ്റാൾ ചെയ്യാൻ ശ്രമിക്കുക."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "मीडिया की ऑफलाइन. इव्हेंट टॅप पुन्हा स्थापित करण्यासाठी पुन्हा प्रयत्न करा."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Medietaster offline. Prøv på nytt for å installere hendelsestappen på nytt."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ଅଫଲାଇନରେ ମିଡିଆ କିଗୁଡ଼ିକ | ଇଭେଣ୍ଟ ଟ୍ୟାପ୍ ପୁନ rein ସଂସ୍ଥାପନ କରିବାକୁ ଚେଷ୍ଟା କରନ୍ତୁ |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klawisze multimedialne w trybie offline. Spróbuj ponownie zainstalować dotknięcie zdarzenia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaves de mídia offline. Tente reinstalar novamente o evento tap."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaves de mídia offline. Tente reinstalar novamente o evento tap."
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ਮੀਡੀਆ ਕੁੰਜੀਆਂ ਔਫਲਾਈਨ। ਇਵੈਂਟ ਟੈਪ ਨੂੰ ਮੁੜ ਸਥਾਪਿਤ ਕਰਨ ਦੀ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Tastele media offline. Reîncercați să reinstalați robinetul evenimentului."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Медиа-ключи отключены. Повторите попытку переустановки события."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Mediálne klávesy offline. Pokúste sa znova nainštalovať klepnutie na udalosť."
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "Medijske tipke brez povezave. Znova poskusite znova namestiti pipo za dogodek."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Teclas multimedia sin conexión. Vuelva a intentar reinstalar el grifo de eventos."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Teclas multimedia sin conexión. Vuelva a intentar reinstalar el grifo de eventos."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Medianycklar offline. Försök igen att installera om händelsetrycket."
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "மீடியா விசைகள் ஆஃப்லைனில் உள்ளன. நிகழ்வு தட்டலை மீண்டும் நிறுவ முயற்சிக்கவும்."
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "మీడియా కీలు ఆఫ్‌లైన్‌లో ఉన్నాయి. ఈవెంట్ ట్యాప్‌ని మళ్లీ ఇన్‌స్టాల్ చేయడానికి మళ్లీ ప్రయత్నించండి."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "มีเดียคีย์ครับ ลองติดตั้งการแตะเหตุการณ์อีกครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Medya tuşları çevrimdışı. Etkinlik dokunuşunu yeniden yüklemeyi deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Медіа-клавіші офлайн. Спробуйте повторно встановити кран подій."
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "میڈیا کیز آف لائن۔ ایونٹ ٹیپ کو دوبارہ انسٹال کرنے کی کوشش کریں۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phím phương tiện ngoại tuyến. Hãy thử cài đặt lại vòi sự kiện."
          }
        }
      }
    },
