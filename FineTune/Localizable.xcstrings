          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Prevent auto-switching when devices connect"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Estä automaattinen vaihto laitteiden yhteydessä"
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Empêcher la commutation automatique lorsque les appareils se connectent"
