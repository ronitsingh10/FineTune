    "Media keys offline. Retry to reinstall the event tap.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "媒体键离线。重试以重新安装事件 tap。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "مفاتيح الوسائط غير متصلة بالإنترنت. أعد محاولة إعادة تثبيت صنبور الحدث."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "মিডিয়া কী অফলাইন। ইভেন্ট ট্যাপ পুনরায় ইনস্টল করার জন্য পুনরায় চেষ্টা করুন."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tecles multimèdia fora de línia. Torna a provar de tornar a instal·lar el toc de l'esdeveniment."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "媒體鍵離線。重試重新安裝事件水龍頭。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Medijske tipke izvan mreže. Pokušajte ponovo instalirati slavinu događaja."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Mediální klíče offline. Zkuste znovu nainstalovat kohoutek události."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Medietaster offline. Prøv igen at geninstallere hændelsestryk."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Mediatoetsen offline. Probeer opnieuw de gebeurtenistap opnieuw te installeren."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Media keys offline. Retry to reinstall the event tap."
          }
        },
