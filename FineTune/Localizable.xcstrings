        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" परत आला आहे. %lld ॲप(चे) परत स्विच केले."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" er tilbake. %lld app(er) byttet tilbake."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ଫେରି ଆସିଛି | %lld ଆପ୍ (ଗୁଡିକ) ପଛକୁ ସୁଇଚ୍ ହେଲା |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@” powrócił. %lld aplikacje zostały ponownie włączone."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" está de volta. Os aplicativos %lld voltaram."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" está de volta. Os aplicativos %lld voltaram."
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ਵਾਪਸ ਆ ਗਿਆ ਹੈ। %lld ਐਪ(ਆਂ) ਨੂੰ ਵਾਪਸ ਬਦਲਿਆ ਗਿਆ।"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@” a revenit. Aplicația(ele) %lld au fost comutate înapoi."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" вернулся. %lld приложения переключены обратно."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" je späť. Aplikácia %lld bola prepnutá späť."
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" je nazaj. %lld aplikacije so preklopljene nazaj."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ha vuelto. %lld las aplicaciones volvieron a cambiar."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" ha vuelto. %lld las aplicaciones volvieron a cambiar."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" är tillbaka. %lld app(ar) bytte tillbaka."
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" மீண்டும் வந்துவிட்டது. %lld பயன்பாடு(கள்) மீண்டும் மாறியது."
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" తిరిగి వచ్చింది. %lld యాప్(లు) తిరిగి మార్చబడ్డాయి."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" กลับมาแล้ว %lld เปลี่ยนแอปกลับแล้ว"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" geri döndü. %lld uygulama(lar) geri alındı."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" повернувся. Програми %lld повернуто назад."
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" واپس آ گیا ہے۔ %lld ایپ (ایپ) کو واپس بدل دیا گیا۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" đã trở lại. (Các) ứng dụng %lld đã chuyển trở lại."
          }
        }
