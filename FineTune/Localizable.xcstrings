        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ਪਹੁੰਚ ਦਿੱਤੀ ਗਈ — ਵਾਲੀਅਮ ਕੁੰਜੀਆਂ ਹੁਣ FineTune ਨੂੰ ਕੰਟਰੋਲ ਕਰਦੀਆਂ ਹਨ।"
          }
        },
