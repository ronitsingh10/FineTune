    "Access granted — volume keys now control FineTune.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "访问权限已授予，音量键现在会控制 FineTune。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "تم منح الوصول - تتحكم مفاتيح مستوى الصوت الآن في FineTune."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "অ্যাক্সেস দেওয়া হয়েছে — ভলিউম কী এখন নিয়ন্ত্রণ করে FineTune।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Accés concedit: ara les tecles de volum controlen FineTune."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已授予存取權限 — 音量鍵現在控制FineTune。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pristup odobren — tipke za glasnoću sada kontroliraju FineTune."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přístup udělen – tlačítka hlasitosti nyní ovládají FineTune."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Adgang givet — lydstyrketasterne styrer nu FineTune."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Toegang verleend — volumetoetsen bedienen nu FineTune."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Access granted — volume keys now control FineTune."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Access granted — volume keys now control FineTune."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Access granted — volume keys now control FineTune."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Access granted — volume keys now control FineTune."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käyttöoikeus myönnetty — äänenvoimakkuusnäppäimillä ohjataan nyt FineTune."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Accès accordé — les touches de volume contrôlent désormais FineTune."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Accès accordé — les touches de volume contrôlent désormais FineTune."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff gewährt – Lautstärketasten steuern jetzt FineTune."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Παραχωρήθηκε πρόσβαση — τα πλήκτρα έντασης ελέγχου πλέον το FineTune."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ઍક્સેસ મંજૂર — વોલ્યુમ કી હવે FineTune નિયંત્રિત કરે છે."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ניתנה גישה - מקשי עוצמת הקול שולטים כעת FineTune."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पहुंच प्रदान की गई - वॉल्यूम कुंजियाँ अब FineTune को नियंत्रित करती हैं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hozzáférés megadva — a hangerőszabályzók mostantól a FineTune vezérlést."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses diberikan — tombol volume kini mengontrol FineTune."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso concesso: i tasti del volume ora controllano FineTune."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセスが許可されました — ボリューム キーは FineTune を制御するようになりました。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಪ್ರವೇಶವನ್ನು ನೀಡಲಾಗಿದೆ - ವಾಲ್ಯೂಮ್ ಕೀಗಳು ಈಗ FineTune ಅನ್ನು ನಿಯಂತ್ರಿಸುತ್ತವೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "액세스 권한이 부여되었습니다. 이제 볼륨 키가 FineTune을 제어합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Akses diberikan — kekunci kelantangan kini mengawal FineTune."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ആക്സസ് അനുവദിച്ചു - വോളിയം കീകൾ ഇപ്പോൾ FineTune നിയന്ത്രിക്കുന്നു."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रवेश मंजूर — व्हॉल्यूम की आता FineTune नियंत्रित करतात."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Tilgang gitt — volumtastene styrer nå FineTune."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ଆକ୍ସେସ୍ ମଞ୍ଜୁର - ଭଲ୍ୟୁମ୍ କିଗୁଡ଼ିକ ବର୍ତ୍ତମାନ FineTune କୁ ନିୟନ୍ତ୍ରଣ କରେ |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dostęp przyznany — klawisze głośności sterują teraz FineTune."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acesso concedido — as teclas de volume agora controlam FineTune."
          }
        },
        "pt-PT": {
