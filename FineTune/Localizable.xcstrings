    "Turn on only if the volume slider doesn't work. FineTune remembers this for each device.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在音量滑块不起作用时开启。FineTune 会为每台设备记住此设置。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بالتشغيل فقط إذا كان شريط تمرير مستوى الصوت لا يعمل. FineTune يتذكر هذا لكل جهاز."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "শুধুমাত্র ভলিউম স্লাইডার কাজ না করলেই চালু করুন। FineTune প্রতিটি ডিভাইসের জন্য এটি মনে রাখে।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Enceneu només si el control lliscant de volum no funciona. FineTune ho recorda per a cada dispositiu."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅當音量滑桿不起作用時才開啟。 FineTune 會為每個裝置記住這一點。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uključi samo ako klizač za glasnoću ne radi. FineTune pamti ovo za svaki uređaj."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapněte pouze v případě, že posuvník hlasitosti nefunguje. FineTune si to pamatuje pro každé zařízení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tænd kun, hvis lydstyrkeskyderen ikke virker. FineTune husker dette for hver enhed."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen inschakelen als de volumeschuifregelaar niet werkt. FineTune onthoudt dit voor elk apparaat."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on only if the volume slider doesn't work. FineTune remembers this for each device."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on only if the volume slider doesn't work. FineTune remembers this for each device."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on only if the volume slider doesn't work. FineTune remembers this for each device."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on only if the volume slider doesn't work. FineTune remembers this for each device."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kytke päälle vain, jos äänenvoimakkuuden liukusäädin ei toimi. FineTune muistaa tämän jokaiselle laitteelle."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez-le uniquement si le curseur de volume ne fonctionne pas. FineTune s'en souvient pour chaque appareil."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez-le uniquement si le curseur de volume ne fonctionne pas. FineTune s'en souvient pour chaque appareil."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur einschalten, wenn der Lautstärkeregler nicht funktioniert. FineTune merkt sich dies für jedes Gerät."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ενεργοποιήστε μόνο εάν το ρυθμιστικό έντασης δεν λειτουργεί. Το FineTune το θυμάται αυτό για κάθε συσκευή."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "જો વોલ્યુમ સ્લાઇડર કામ ન કરે તો જ ચાલુ કરો. FineTune દરેક ઉપકરણ માટે આ યાદ રાખે છે."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הפעל רק אם מחוון עוצמת הקול אינו פועל. FineTune זוכר זאת עבור כל מכשיר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल तभी चालू करें जब वॉल्यूम स्लाइडर काम न करे। FineTune इसे प्रत्येक डिवाइस के लिए याद रखता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Csak akkor kapcsolja be, ha a hangerő-csúszka nem működik. FineTune ezt minden eszköznél megjegyzi."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan hanya jika penggeser volume tidak berfungsi. FineTune mengingat ini untuk setiap perangkat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva solo se il cursore del volume non funziona. FineTune lo ricorda per ciascun dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音量スライダーが機能しない場合にのみオンにします。 FineTune はこれをデバイスごとに記憶します。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ವಾಲ್ಯೂಮ್ ಸ್ಲೈಡರ್ ಕೆಲಸ ಮಾಡದಿದ್ದರೆ ಮಾತ್ರ ಆನ್ ಮಾಡಿ. ಪ್ರತಿ ಸಾಧನಕ್ಕೆ FineTune ಇದನ್ನು ನೆನಪಿಸುತ್ತದೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "볼륨 슬라이더가 작동하지 않는 경우에만 켜십시오. FineTune은 각 장치에 대해 이를 기억합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Hidupkan hanya jika peluncur kelantangan tidak berfungsi. FineTune mengingati ini untuk setiap peranti."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "വോളിയം സ്ലൈഡർ പ്രവർത്തിക്കുന്നില്ലെങ്കിൽ മാത്രം ഓണാക്കുക. ഓരോ ഉപകരണത്തിനും FineTune ഇത് ഓർമ്മിക്കുന്നു."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "व्हॉल्यूम स्लाइडर काम करत नसेल तरच चालू करा. FineTune हे प्रत्येक उपकरणासाठी लक्षात ठेवते."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Slå på bare hvis volumskyveknappen ikke fungerer. FineTune husker dette for hver enhet."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ଭଲ୍ୟୁମ୍ ସ୍ଲାଇଡର୍ କାମ ନକଲେ କେବଳ ଟର୍ନ୍ ଅନ୍ କରନ୍ତୁ | FineTune ପ୍ରତ୍ୟେକ ଉପକରଣ ପାଇଁ ଏହାକୁ ମନେ ରଖିଥାଏ |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz tylko wtedy, gdy suwak głośności nie działa. FineTune zapamiętuje to dla każdego urządzenia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative somente se o controle deslizante de volume não funcionar. FineTune lembra disso para cada dispositivo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative somente se o controle deslizante de volume não funcionar. FineTune lembra disso para cada dispositivo."
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ਸਿਰਫ ਤਾਂ ਹੀ ਚਾਲੂ ਕਰੋ ਜੇਕਰ ਵਾਲੀਅਮ ਸਲਾਈਡਰ ਕੰਮ ਨਹੀਂ ਕਰਦਾ ਹੈ। FineTune ਇਸ ਨੂੰ ਹਰੇਕ ਡਿਵਾਈਸ ਲਈ ਯਾਦ ਰੱਖਦਾ ਹੈ।"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Porniți numai dacă glisorul de volum nu funcționează. FineTune își amintește acest lucru pentru fiecare dispozitiv."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включайте только если не работает ползунок громкости. FineTune запоминает это для каждого устройства."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapnite iba v prípade, že posúvač hlasitosti nefunguje. FineTune si to pamätá pre každé zariadenie."
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "Vklopi le, če drsnik za glasnost ne deluje. FineTune si to zapomni za vsako napravo."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Actívelo solo si el control deslizante de volumen no funciona. FineTune recuerda esto para cada dispositivo."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Actívelo solo si el control deslizante de volumen no funciona. FineTune recuerda esto para cada dispositivo."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Slå på endast om volymreglaget inte fungerar. FineTune kommer ihåg detta för varje enhet."
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "வால்யூம் ஸ்லைடர் வேலை செய்யவில்லை என்றால் மட்டும் இயக்கவும். ஒவ்வொரு சாதனத்திற்கும் FineTune இதை நினைவில் கொள்கிறது."
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "వాల్యూమ్ స్లయిడర్ పని చేయకపోతే మాత్రమే ఆన్ చేయండి. FineTune ప్రతి పరికరానికి దీన్ని గుర్తుంచుకుంటుంది."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดเฉพาะเมื่อแถบเลื่อนระดับเสียงไม่ทำงาน FineTune จดจำสิ่งนี้สำหรับแต่ละอุปกรณ์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca ses düzeyi kaydırıcısı çalışmıyorsa açın. FineTune bunu her cihaz için hatırlar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вмикайте, лише якщо повзунок гучності не працює. FineTune запам'ятовує це для кожного пристрою."
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "صرف اس صورت میں آن کریں جب والیوم سلائیڈر کام نہ کرے۔ FineTune اسے ہر ڈیوائس کے لیے یاد رکھتا ہے۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chỉ bật nếu thanh trượt âm lượng không hoạt động. FineTune ghi nhớ điều này cho từng thiết bị."
          }
        }
      }
    },
