    "The system disabled FineTune's event tap — usually after a sleep/wake cycle or a main-thread stall. Retry to reinstall it.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统已停用 FineTune 的事件 tap，通常发生在睡眠/唤醒后或主线程卡顿后。请重试以重新安装。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "قام النظام بتعطيل النقر على حدث FineTune - عادةً بعد دورة السكون/الاستيقاظ أو توقف الخيط الرئيسي. أعد محاولة إعادة تثبيته."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "সিস্টেমটি FineTune এর ইভেন্ট ট্যাপ নিষ্ক্রিয় করেছে — সাধারণত একটি ঘুম/জাগরণ চক্র বা একটি প্রধান-থ্রেড স্টলের পরে। এটি পুনরায় ইনস্টল করার চেষ্টা করুন।"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema ha desactivat el toc d'esdeveniment de FineTune, normalment després d'un cicle de repòs/despertador o d'una parada del fil principal. Torneu a provar de reinstal·lar-lo."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統禁用了FineTune 的事件點擊——通常是在睡眠/喚醒週期或主執行緒停頓之後。重新嘗試重新安裝它。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sustav je onemogućio dodir događaja FineTune — obično nakon ciklusa spavanja/buđenja ili zastoja glavne niti. Pokušajte ponovno instalirati."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Systém zakázal klepnutí na událost FineTune — obvykle po cyklu spánku/probuzení nebo po zablokování hlavního vlákna. Zkuste jej znovu nainstalovat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemet deaktiverede FineTunes hændelsestryk — normalt efter en søvn-/vågningscyklus eller en hovedtrådsstop. Prøv igen at geninstallere det."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Het systeem heeft de gebeurtenistap van FineTune uitgeschakeld — meestal na een slaap/waakcyclus of een hoofdonderbreking. Probeer het opnieuw te installeren."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "The system disabled FineTune's event tap — usually after a sleep/wake cycle or a main-thread stall. Retry to reinstall it."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "The system disabled FineTune's event tap — usually after a sleep/wake cycle or a main-thread stall. Retry to reinstall it."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "The system disabled FineTune's event tap — usually after a sleep/wake cycle or a main-thread stall. Retry to reinstall it."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "The system disabled FineTune's event tap — usually after a sleep/wake cycle or a main-thread stall. Retry to reinstall it."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Järjestelmä poisti FineTune tapahtuman napautuksen käytöstä – yleensä uni-/herätysjakson tai pääsäikeen pysähtymisen jälkeen. Yritä asentaa se uudelleen."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Le système a désactivé le tap d'événement de FineTune - généralement après un cycle veille/veille ou un blocage du thread principal. Réessayez de le réinstaller."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Le système a désactivé le tap d'événement de FineTune - généralement après un cycle veille/veille ou un blocage du thread principal. Réessayez de le réinstaller."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Das System hat den Ereignisabgriff von FineTune deaktiviert – normalerweise nach einem Schlaf-/Wachzyklus oder einem Stillstand des Haupt-Threads. Versuchen Sie es erneut."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το σύστημα απενεργοποίησε το πάτημα συμβάντων του FineTune — συνήθως μετά από έναν κύκλο ύπνου/αφύπνισης ή μετά από διακοπή του κύριου νήματος. Δοκιμάστε ξανά να το εγκαταστήσετε ξανά."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "સિસ્ટમે FineTuneના ઇવેન્ટ ટેપને અક્ષમ કર્યું — સામાન્ય રીતે સ્લીપ/વેક સાયકલ અથવા મુખ્ય-થ્રેડ સ્ટોલ પછી. તેને ફરીથી ઇન્સ્ટોલ કરવાનો પ્રયાસ કરો."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המערכת השביתה את הברז האירועים של FineTune - בדרך כלל לאחר מחזור שינה/ערות או עצירת חוט ראשי. נסה שוב להתקין אותו מחדש."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम ने FineTune के इवेंट टैप को अक्षम कर दिया है - आमतौर पर नींद/जागने के चक्र या मुख्य-थ्रेड स्टॉल के बाद। इसे पुनः स्थापित करने का पुनः प्रयास करें."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A rendszer letiltotta FineTune eseményérintését – általában alvási/ébresztési ciklus vagy főszál leállása után. Próbálja újra telepíteni."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem menonaktifkan ketukan acara FineTune — biasanya setelah siklus tidur/bangun atau penghentian thread utama. Coba instal ulang lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il sistema ha disabilitato il tocco dell'evento di FineTune, in genere dopo un ciclo di sospensione/riattivazione o uno stallo del thread principale. Riprovare a reinstallarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムは、FineTune のイベント タップを無効にしました。通常は、スリープ/ウェイク サイクルまたはメインスレッドのストールの後です。再インストールを再試行してください。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಸಿಸ್ಟಂ FineTune ನ ಈವೆಂಟ್ ಟ್ಯಾಪ್ ಅನ್ನು ನಿಷ್ಕ್ರಿಯಗೊಳಿಸಲಾಗಿದೆ — ಸಾಮಾನ್ಯವಾಗಿ ನಿದ್ರೆ/ವೇಕ್ ಸೈಕಲ್ ಅಥವಾ ಮುಖ್ಯ-ಥ್ರೆಡ್ ಸ್ಟಾಲ್ ನಂತರ. ಅದನ್ನು ಮರುಸ್ಥಾಪಿಸಲು ಮರುಪ್ರಯತ್ನಿಸಿ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템은 FineTune의 이벤트 탭을 비활성화했습니다. 일반적으로 절전/깨우기 주기 또는 메인 스레드 정지 후에 발생합니다. 다시 설치해 보세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem melumpuhkan ketik acara FineTune — biasanya selepas kitaran tidur/bangun atau gerai utas utama. Cuba pasang semula."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "സിസ്റ്റം FineTune ൻ്റെ ഇവൻ്റ് ടാപ്പ് പ്രവർത്തനരഹിതമാക്കി — സാധാരണയായി ഉറക്കം/ഉണർവ് സൈക്കിൾ അല്ലെങ്കിൽ മെയിൻ-ത്രെഡ് സ്റ്റാൾ എന്നിവയ്ക്ക് ശേഷം. ഇത് വീണ്ടും ഇൻസ്റ്റാൾ ചെയ്യാൻ ശ്രമിക്കുക."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टीमने FineTune चा इव्हेंट टॅप अक्षम केला — सहसा स्लीप/वेक सायकल किंवा मुख्य-थ्रेड स्टॉल नंतर. ते पुन्हा स्थापित करण्याचा प्रयत्न करा."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemet deaktiverte FineTunes hendelsestrykk — vanligvis etter en søvn-/våknesyklus eller en hovedtrådstopp. Prøv å installere den på nytt."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ସିଷ୍ଟମ୍ ଅକ୍ଷମ ହୋଇଛି FineTune ଇଭେଣ୍ଟ ଟ୍ୟାପ୍ - ସାଧାରଣତ a ଏକ ଶୋଇବା / ଜାଗ୍ରତ ଚକ୍ର କିମ୍ବା ଏକ ମୁଖ୍ୟ-ଥ୍ରେଡ୍ ଷ୍ଟଲ୍ ପରେ | ଏହାକୁ ପୁନ rein ସଂସ୍ଥାପନ କରିବାକୁ ଚେଷ୍ଟା କରନ୍ତୁ |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "System wyłączył dotknięcie zdarzenia FineTune — zwykle po cyklu uśpienia/wybudzenia lub zawieszeniu głównego wątku. Spróbuj ponownie zainstalować."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema desabilitou o tap de evento do FineTune - geralmente após um ciclo de suspensão/despertar ou uma parada do thread principal. Tente reinstalá-lo novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema desabilitou o tap de evento do FineTune - geralmente após um ciclo de suspensão/despertar ou uma parada do thread principal. Tente reinstalá-lo novamente."
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ਸਿਸਟਮ ਨੇ FineTune ਦੇ ਇਵੈਂਟ ਟੈਪ ਨੂੰ ਅਯੋਗ ਕਰ ਦਿੱਤਾ ਹੈ — ਆਮ ਤੌਰ 'ਤੇ ਸਲੀਪ/ਵੇਕ ਚੱਕਰ ਜਾਂ ਮੁੱਖ-ਥਰਿੱਡ ਸਟਾਲ ਤੋਂ ਬਾਅਦ। ਇਸਨੂੰ ਮੁੜ ਸਥਾਪਿਤ ਕਰਨ ਦੀ ਕੋਸ਼ਿਸ਼ ਕਰੋ।"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistemul a dezactivat atingerea evenimentului lui FineTune – de obicei după un ciclu de repaus/trezire sau o blocare a firului principal. Reîncercați să-l reinstalați."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Система отключила перехват событий FineTune — обычно после цикла сна/пробуждения или остановки основного потока. Повторите попытку переустановить его."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Systém zakázal klepnutie na udalosť FineTune — zvyčajne po cykle spánku/prebudenia alebo po zastavení hlavného vlákna. Skúste ho znova nainštalovať."
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem je onemogočil dotik dogodka FineTune — običajno po ciklu spanja/bujenja ali zastoju glavne niti. Poskusite znova namestiti."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema deshabilitó el tap de eventos de FineTune, generalmente después de un ciclo de suspensión/activación o de una parada del hilo principal. Vuelva a intentar reinstalarlo."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "El sistema deshabilitó el tap de eventos de FineTune, generalmente después de un ciclo de suspensión/activación o de una parada del hilo principal. Vuelva a intentar reinstalarlo."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Systemet inaktiverade FineTunes händelsetryckning — vanligtvis efter en sömn-/väckningscykel eller en huvudtrådsstopp. Försök att installera om den igen."
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "சிஸ்டம் FineTune இன் நிகழ்வுத் தட்டலை முடக்கியது — பொதுவாக உறக்கம்/விழிப்பு சுழற்சி அல்லது பிரதான நூல் ஸ்டாலுக்குப் பிறகு. அதை மீண்டும் நிறுவ முயற்சிக்கவும்."
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "సిస్టమ్ FineTune యొక్క ఈవెంట్ ట్యాప్‌ను నిలిపివేసింది — సాధారణంగా నిద్ర/వేక్ సైకిల్ లేదా మెయిన్-థ్రెడ్ స్టాల్ తర్వాత. దాన్ని మళ్లీ ఇన్‌స్టాల్ చేయడానికి ప్రయత్నించండి."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ระบบปิดการใช้งานการแตะเหตุการณ์ของ FineTune — โดยปกติหลังจากรอบการนอนหลับ/ตื่นหรือแผงเธรดหลัก ลองติดตั้งใหม่อีกครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem, FineTune'nin olay dokunuşunu devre dışı bıraktı — genellikle uyku/uyanma döngüsünden veya ana iş parçacığının durmasından sonra. Yeniden yüklemeyi yeniden deneyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Система вимкнула натискання подій FineTune — зазвичай після циклу сну/пробудження або зупинки основного потоку. Спробуйте перевстановити його."
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "سسٹم نے FineTune کے ایونٹ ٹیپ کو غیر فعال کردیا — عام طور پر نیند/جاگنے کے چکر یا مین تھریڈ اسٹال کے بعد۔ اسے دوبارہ انسٹال کرنے کی کوشش کریں۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hệ thống đã vô hiệu hóa thao tác nhấn sự kiện của FineTune — thường là sau chu kỳ ngủ/thức hoặc ngừng hoạt động của luồng chính. Hãy thử cài đặt lại nó."
          }
        }
      }
    },
