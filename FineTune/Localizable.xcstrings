        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಎಲ್ಲಾ ಸಂಪುಟಗಳನ್ನು ತೆರವುಗೊಳಿಸಿ, EQ, ಮತ್ತು ಸಾಧನ ರೂಟಿಂಗ್‌ಗಳು"
