    "Prevent auto-switching when devices connect": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "防止设备连接时自动切换"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "منع التبديل التلقائي عند اتصال الأجهزة"
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "ডিভাইস সংযুক্ত হলে স্বয়ংক্রিয়-সুইচিং প্রতিরোধ করুন"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Eviteu el canvi automàtic quan els dispositius es connecten"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "防止裝置連線時自動切換"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Spriječi automatsko prebacivanje kada se uređaji povežu"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zabránit automatickému přepínání při připojení zařízení"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Forhindrer automatisk skift, når enheder tilsluttes"
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Voorkom automatisch schakelen wanneer apparaten verbinding maken"
