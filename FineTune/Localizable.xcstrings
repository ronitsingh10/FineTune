    "Smaller fits more on screen; larger leaves more breathing room.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较小尺寸可显示更多内容；较大尺寸留出更多空间。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "الأصغر يناسب المزيد على الشاشة؛ أكبر يترك مساحة أكبر للتنفس."
          }
        },
        "bn-BD": {
          "stringUnit": {
            "state": "translated",
            "value": "স্ক্রিনে ছোট বেশি ফিট করে; বৃহত্তর পাতা আরো শ্বাস রুম."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Més petit s'adapta més a la pantalla; més grans deixa més espai per respirar."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "較小的尺寸更適合螢幕；更大的空間留下更多的呼吸空間。"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Manji stane više na zaslon; veći ostavlja više prostora za disanje."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Menší se více vejde na obrazovku; větší ponechává více prostoru pro dýchání."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindre passer mere på skærmen; større efterlader mere pusterum."
          }
        },
        "nl-NL": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleiner past meer op het scherm; groter laat meer ademruimte achter."
          }
        },
        "en-AU": {
          "stringUnit": {
            "state": "translated",
            "value": "Smaller fits more on screen; larger leaves more breathing room."
          }
        },
        "en-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Smaller fits more on screen; larger leaves more breathing room."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Smaller fits more on screen; larger leaves more breathing room."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Smaller fits more on screen; larger leaves more breathing room."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pienempi mahtuu enemmän näytölle; suurempi jättää enemmän hengitystilaa."
          }
        },
        "fr-FR": {
          "stringUnit": {
            "state": "translated",
            "value": "Plus petit, plus adapté à l'écran ; plus grand laisse plus d’espace pour respirer."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Plus petit, plus adapté à l'écran ; plus grand laisse plus d’espace pour respirer."
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleiner passt besser auf den Bildschirm; Größer lässt mehr Raum zum Atmen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το μικρότερο ταιριάζει περισσότερο στην οθόνη. μεγαλύτερο αφήνει περισσότερο χώρο αναπνοής."
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "નાનું સ્ક્રીન પર વધુ બંધબેસે છે; મોટા પાંદડા વધુ શ્વાસ રૂમ."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קטן יותר מתאים יותר למסך; גדול יותר משאיר יותר מרחב נשימה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "छोटा स्क्रीन पर अधिक फिट बैठता है; बड़ी पत्तियों में सांस लेने की अधिक जगह होती है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kisebb több elfér a képernyőn; a nagyobb több helyet hagy a légzésnek."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lebih kecil lebih pas di layar; lebih besar menyisakan lebih banyak ruang bernapas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Più piccolo si adatta di più allo schermo; più grande lascia più respiro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "小さいほど画面にフィットします。大きいほど、より多くの呼吸スペースが残ります。"
          }
        },
        "kn-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ಚಿಕ್ಕದು ಪರದೆಯ ಮೇಲೆ ಹೆಚ್ಚು ಹೊಂದಿಕೊಳ್ಳುತ್ತದೆ; ದೊಡ್ಡ ಎಲೆಗಳು ಹೆಚ್ಚು ಉಸಿರಾಟದ ಕೋಣೆ."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작을수록 화면에 더 잘 맞습니다. 더 큰 것은 더 많은 호흡 공간을 제공합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lebih kecil lebih muat pada skrin; lebih besar meninggalkan lebih banyak ruang pernafasan."
          }
        },
        "ml-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "സ്‌ക്രീനിൽ ചെറുത് കൂടുതൽ യോജിക്കുന്നു; വലിയ ഇലകൾ കൂടുതൽ ശ്വസിക്കാനുള്ള മുറി."
          }
        },
        "mr-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "लहान स्क्रीनवर अधिक बसते; मोठी पाने अधिक श्वास घेण्याची खोली."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindre passer mer på skjermen; større gir mer pusterom."
          }
        },
        "or-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ଛୋଟ ପରଦାରେ ଅଧିକ ଫିଟ୍ ହୁଏ; ବଡ଼ ପତ୍ର ଅଧିକ ନିଶ୍ୱାସ ପ୍ରଶ୍ୱାସ ଛାଡିଥାଏ |"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mniejszy mieści się bardziej na ekranie; większe pozostawiają więcej miejsca do oddychania."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Menor cabe mais na tela; maior deixa mais espaço para respirar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Menor cabe mais na tela; maior deixa mais espaço para respirar."
          }
        },
        "pa-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "ਛੋਟਾ ਸਕਰੀਨ 'ਤੇ ਜ਼ਿਆਦਾ ਫਿੱਟ ਬੈਠਦਾ ਹੈ; ਵੱਡੇ ਪੱਤੇ ਸਾਹ ਲੈਣ ਦਾ ਕਮਰਾ।"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Mai mic se potrivește mai mult pe ecran; mai mare lasă mai mult spațiu de respirație."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Меньший размер больше помещается на экране; больший размер оставляет больше места для передышки."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Menšie sa viac zmestí na obrazovku; väčšie ponecháva viac priestoru na dýchanie."
          }
        },
        "sl-SI": {
          "stringUnit": {
            "state": "translated",
            "value": "Manjši se bolj prilega zaslonu; večji pusti več prostora za dihanje."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuanto más pequeño cabe más en la pantalla; más grande deja más espacio para respirar."
          }
        },
        "es-ES": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuanto más pequeño cabe más en la pantalla; más grande deja más espacio para respirar."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindre passar mer på skärmen; större ger mer andningsutrymme."
          }
        },
        "ta-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "சிறியது திரையில் அதிகம் பொருந்துகிறது; பெரிய இலைகள் அதிக சுவாச அறை."
          }
        },
        "te-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "స్క్రీన్‌పై చిన్నది మరింత సరిపోతుంది; పెద్ద ఆకులు ఎక్కువ శ్వాస గది."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เล็กลงพอดีกับหน้าจอมากขึ้น ใหญ่ขึ้นทำให้มีห้องหายใจมากขึ้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha küçük olanı ekrana daha çok sığar; daha büyük, daha fazla nefes alma alanı bırakır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Менше підходить більше на екрані; більший залишає більше місця для дихання."
          }
        },
        "ur-PK": {
          "stringUnit": {
            "state": "translated",
            "value": "چھوٹا اسکرین پر زیادہ فٹ بیٹھتا ہے۔ بڑے پتے زیادہ سانس لینے کا کمرہ۔"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhỏ hơn vừa vặn hơn trên màn hình; lá lớn hơn có nhiều không gian thở hơn."
          }
        }
      }
    },
