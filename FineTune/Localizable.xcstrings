        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Megakadályozza az automatikus váltást az eszközök csatlakoztatásakor"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mencegah peralihan otomatis saat perangkat terhubung"
