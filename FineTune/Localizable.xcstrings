        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αποτρέψτε την αυτόματη εναλλαγή κατά τη σύνδεση των συσκευών"
          }
        },
        "gu-IN": {
          "stringUnit": {
            "state": "translated",
            "value": "જ્યારે ઉપકરણો કનેક્ટ થાય ત્યારે સ્વતઃ-સ્વિચિંગને અટકાવો"
