    "\"%@\" is back. %lld app(s) switched back.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”已重新连接。%lld 个 App 已切换回来。"
          }
        },
        "ar-SA": {
          "stringUnit": {
            "state": "translated",
            "value": "عاد \"%@\". تم تبديل التطبيق (التطبيقات) %lld مرة أخرى."
