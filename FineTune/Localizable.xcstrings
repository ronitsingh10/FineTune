        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Empêcher la commutation automatique lorsque les appareils se connectent"
          }
        },
        "de-DE": {
          "stringUnit": {
            "state": "translated",
            "value": "Verhindern Sie die automatische Umschaltung, wenn Geräte verbunden werden"
